{
  "info": {
    "name": "Inclusão & Diversidade API",
    "_postman_id": "a1b2c3d4-0000-4000-8000-inclusaodiv01",
    "description": "Coleção de testes da API ESG (FIAP). 'Gerar token' salva o JWT em {{token}} automaticamente.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Gerar token (admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/token",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "token"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var data = pm.response.json();",
                  "if (data && data.access_token) {",
                  "    pm.collectionVariables.set('token', data.access_token);",
                  "    console.log('Token salvo na variável {{token}}.');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
